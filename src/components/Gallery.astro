---
/*
  Gallery component
  - supports featured + masonry (manual mode)
  - supports auto-loading from folder (new)
  - includes fullscreen lightbox
*/

interface ImageItem {
  src: string;
  alt?: string;
}

const {
  title,
  metaLines = [],
  featured = [],
  images = [],
  folder
} = Astro.props as {
  title?: string;
  metaLines?: string[];
  featured?: ImageItem[];
  images?: ImageItem[];
  folder?: string;
};

/* ----------------------------------
   AUTO LOAD IMAGES FROM FOLDER
---------------------------------- */

let autoImages: ImageItem[] = [];

if (folder) {
  const modules = import.meta.glob('/public/images/**/*.{jpg,jpeg,png}', {
    eager: true
  });

  autoImages = Object.keys(modules)
    .filter((path) => path.includes(`/images/${folder}/`))
    .sort()
    .map((path) => ({
      src: path.replace('/public', '')
    }));
}

/* ----------------------------------
   FINAL IMAGE SET
---------------------------------- */

const finalImages = folder ? autoImages : images;
---

<div class="gallery-wrap">

  {title && <h2 class="gallery-title">{title}</h2>}

  {metaLines.length > 0 && (
    <div class="gallery-meta">
      {metaLines.map(line => <div>{line}</div>)}
    </div>
  )}

  <!-- FEATURED (manual only) -->
  {!folder && featured.length > 0 && (
    <div class="featured">
      {featured.map(img => (
        <img
          src={img.src}
          alt={img.alt ?? ""}
          loading="lazy"
          decoding="async"
          class="gallery-img"
        />
      ))}
    </div>
  )}

  <!-- MASONRY -->
  <div class="masonry">
    {finalImages.map(img => (
      <img
        src={img.src}
        alt={img.alt ?? ""}
        loading="lazy"
        decoding="async"
        class="gallery-img"
      />
    ))}
  </div>

</div>

<!-- LIGHTBOX -->
<div id="lightbox" class="lightbox hidden">
  <img id="lightbox-img" />
</div>

<script is:inline>
  const images = document.querySelectorAll('.gallery-img');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');

  images.forEach(img => {
    img.addEventListener('click', () => {
      lightbox.classList.remove('hidden');
      lightboxImg.src = img.src;
    });
  });

  lightbox.addEventListener('click', () => {
    lightbox.classList.add('hidden');
  });
</script>

<style>
.gallery-wrap {
  margin-top: 90px;
  padding-top: 36px;
  border-top: 1px solid rgba(255,255,255,0.1);
}

.gallery-title {
  margin: 0 0 10px;
  font-size: 14px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  opacity: 0.85;
}

.gallery-meta {
  margin: 0 0 28px;
  font-size: 13px;
  color: rgba(234,234,234,0.6);
}

.gallery-meta div {
  margin-bottom: 6px;
}

/* FEATURED */
.featured {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 18px;
  margin-bottom: 18px;
}

/* MASONRY */
.masonry {
  column-count: 3;
  column-gap: 18px;
}

/* IMAGES */
.gallery-img {
  width: 100%;
  height: auto;
  display: block;
  margin-bottom: 18px;
  border-radius: 14px;
  background: #111;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
  cursor: pointer;
  transition: transform 120ms ease, opacity 120ms ease;
}

.gallery-img:hover {
  transform: translateY(-2px);
  opacity: 0.95;
}

/* LIGHTBOX */
.lightbox {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.lightbox img {
  max-width: 92%;
  max-height: 92%;
}

.hidden {
  display: none;
}

/* RESPONSIVE */
@media (max-width: 980px) {
  .featured {
    grid-template-columns: 1fr;
  }

  .masonry {
    column-count: 2;
  }
}

@media (max-width: 620px) {
  .masonry {
    column-count: 1;
  }
}
</style>