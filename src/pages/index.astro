---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "WhatScottSees";
---

<BaseLayout title={title}>
  <h1>WhatScottSees</h1>

  <p>
    Analog photography. An ongoing project and archive made across Scotland and elsewhere — shaped
    by movement, place, and moments that don’t repeat.
  </p>

  <section class="home-hero">
    <img
      src="/images/test/1.jpg"
      alt=""
      loading="eager"
    />
  </section>

  <style is:global>
    /* Home-only styling */
    .home-hero {
      margin-top: 28px;
      margin-bottom: 36px;
    }

    .home-hero img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 14px;
      background: #111;
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 10px 30px rgba(0,0,0,0.35);
    }
  </style>
</BaseLayout>
