---
const title = "WhatScottSees";
const description = "Photography, sound, and slow observation.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0b0b;
        --fg: #eaeaea;
        --muted: rgba(234, 234, 234, 0.75);
        --card: rgba(255, 255, 255, 0.04);
        --border: rgba(255, 255, 255, 0.10);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background:
          radial-gradient(1200px 600px at 20% 0%, rgba(255,255,255,0.06), transparent 60%),
          radial-gradient(900px 500px at 80% 20%, rgba(255,255,255,0.04), transparent 55%),
          var(--bg);
        color: var(--fg);
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, Arial, sans-serif;
        line-height: 1.5;
      }
      a { color: inherit; text-decoration: none; }
      a:hover { text-decoration: underline; }

      .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 48px 20px 80px;
      }
      header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 0 22px;
        border-bottom: 1px solid var(--border);
      }
      .brand {
        letter-spacing: 0.12em;
        font-weight: 300;
        text-transform: uppercase;
        font-size: 18px;
      }
      nav {
        display: flex;
        gap: 18px;
        font-size: 14px;
        opacity: 0.9;
      }

      .hero {
        padding: 54px 0 28px;
      }
      h1 {
        margin: 0 0 14px;
        font-size: clamp(34px, 4vw, 56px);
        font-weight: 300;
        letter-spacing: 0.02em;
      }
      .sub {
        margin: 0;
        max-width: 70ch;
        color: var(--muted);
        font-size: 16px;
      }

      .grid {
        margin-top: 30px;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
      }
      .card {
        grid-column: span 6;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 18px;
        min-height: 120px;
      }
      .card h2 {
        margin: 0 0 8px;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.02em;
      }
      .card p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
      }
      .pill {
        display: inline-block;
        margin-top: 12px;
        font-size: 12px;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        color: rgba(234,234,234,0.85);
      }

      footer {
        margin-top: 46px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        color: rgba(234,234,234,0.65);
        font-size: 12px;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
      }

      @media (max-width: 780px) {
        .card { grid-column: span 12; }
        nav { gap: 12px; }
      }
    </style>
  </head>

  <body>
    <div class="wrap">
      <header>
        <div class="brand">WhatScottSees</div>
        <nav>
          <a href="/projects">Projects</a>
          <a href="/sound">Sound</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </header>

      <section class="hero">
        <h1>Photography. Sound. Place.</h1>
        <p class="sub">
          A quiet archive of analog work, journeys, and field recordings across Scotland and beyond.
        </p>
      </section>

      <section class="grid">
        <a class="card" href="/projects">
          <h2>Projects</h2>
          <p>Series pages with images, notes, and embedded film or sound.</p>
          <span class="pill">View all</span>
        </a>

        <a class="card" href="/sound">
          <h2>Sound</h2>
          <p>Field recordings and long-form ambient soundscapes.</p>
          <span class="pill">Listen</span>
        </a>
      </section>

      <footer>
        <div>© {new Date().getFullYear()} WhatScottSees</div>
        <div>Analog · Slow · Observational</div>
      </footer>
    </div>
  </body>
</html>
