---
const { title = "WhatScottSees" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style is:global>
      :root {
        --bg: #0b0b0b;
        --fg: #eaeaea;
        --border: rgba(255, 255, 255, 0.10);
        --muted: rgba(234, 234, 234, 0.75);
        --soft: rgba(234, 234, 234, 0.55);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        background:
          radial-gradient(1200px 600px at 20% 0%, rgba(255,255,255,0.05), transparent 60%),
          radial-gradient(900px 500px at 80% 20%, rgba(255,255,255,0.03), transparent 55%),
          var(--bg);
        color: var(--fg);
        font-family: system-ui, sans-serif;
        line-height: 1.85;
      }

      header {
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(6px);
      }

      nav {
        max-width: 1100px;
        margin: 0 auto;
        padding:
          18px
          max(20px, env(safe-area-inset-right))
          18px
          max(20px, env(safe-area-inset-left));
        display: flex;
        gap: 18px;
      }

      nav a {
        color: var(--fg);
        text-decoration: none;
        font-size: 14px;
        opacity: 0.85;
      }

      nav a:hover {
        text-decoration: underline;
        opacity: 1;
      }

      main {
        max-width: 1150px;
        margin: 0 auto;
        padding:
          90px
          max(20px, env(safe-area-inset-right))
          120px
          max(20px, env(safe-area-inset-left));
        flex: 1;
      }

      h1 {
        font-weight: 300;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0 0 36px;
      }

      p {
        margin: 0 0 28px;
        color: var(--muted);
        max-width: 78ch;
      }

      /* Gallery */
      .gallery-wrap {
        margin-top: 90px;
        padding-top: 36px;
        border-top: 1px solid var(--border);
      }

      .gallery-title {
        margin: 0 0 10px;
        font-size: 14px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        opacity: 0.85;
      }

      .gallery-meta {
        margin: 0 0 28px;
        font-size: 13px;
        color: var(--soft);
        letter-spacing: 0.02em;
      }

      .gallery-meta div { margin-bottom: 6px; }

      /* Featured row */
      .featured {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 18px;
        margin-bottom: 18px;
      }

      .featured a,
      .masonry a {
        display: block;
        text-decoration: none;
      }

      .featured img,
      .masonry img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 14px;
        background: #111;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 10px 30px rgba(0,0,0,0.35);
        transition: transform 120ms ease, opacity 120ms ease;
      }

      .featured img:hover,
      .masonry img:hover {
        transform: translateY(-2px);
        opacity: 0.95;
      }

      /* Masonry */
      .masonry {
        column-count: 3;
        column-gap: 18px;
      }

      .masonry a {
        display: inline-block;
        width: 100%;
        margin: 0 0 18px;
        break-inside: avoid;
      }

      /* Footer */
      footer {
        margin-top: auto;
        padding:
          28px
          max(20px, env(safe-area-inset-right))
          32px
          max(20px, env(safe-area-inset-left));
        border-top: 1px solid var(--border);
        font-size: 13px;
        color: var(--soft);
        line-height: 1.6;
        max-width: 1150px;
        margin-left: auto;
        margin-right: auto;
      }

      footer div { margin-bottom: 6px; }

      footer a {
        color: inherit;
        text-decoration: none;
      }

      footer a:hover {
        text-decoration: underline;
      }

      @media (max-width: 980px) {
        .featured { grid-template-columns: 1fr; }
        .masonry { column-count: 2; }
      }

      @media (max-width: 620px) {
        .masonry { column-count: 1; }
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        <a href="/test">Test Gallery</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div>Glasgow</div>
      <div>Scotland</div>
      <div>✉ <a href="mailto:info@whatscottsees.com">info@whatscottsees.com</a></div>
    </footer>
  </body>
</html>
